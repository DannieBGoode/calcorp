---
import Container from "@components/container.astro";
import Layout from "@layouts/Layout.astro";
---

<Layout title="404 Not Found">
  <Container>
    <div class="min-h-[calc(100vh-16rem)] flex items-center justify-center">
      <div class="mt-16 text-center max-w-md">
        <p class="text-sm font-semibold uppercase tracking-widest text-slate-400 mb-4">404</p>
        <h1 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">This page doesn't exist.</h1>
        <p class="text-lg mt-4 text-slate-500">It might have moved, or maybe it never existed — like that perfect project brief.</p>
        <a
          href="/"
          class="inline-flex items-center gap-2 mt-8 px-5 py-2.5 bg-black text-white rounded text-sm font-medium hover:-translate-y-px active:translate-y-px transition">
          ← Back home
        </a>
      </div>
    </div>
  </Container>
</Layout>
