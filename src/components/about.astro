---
import { Picture } from "astro:assets";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";

interface AboutProps {
  texts: {
    title: string;
    description: string;
    heading: string;
    paragraph: string;
  };
  teamMembers: Array<{
    data: {
      avatar: {
        src: string;
        alt: string;
      };
      name: string;
      title: string;
    };
  }>;
}

const { texts, teamMembers } = Astro.props as AboutProps;
---

<Container>
  <Sectionhead>
    <Fragment slot="title">{texts.title}</Fragment>
    <Fragment slot="desc">{texts.description}</Fragment>
  </Sectionhead>

  <div class="flex flex-col gap-3 mx-auto max-w-4xl mt-16">
    <h2 class="font-bold text-3xl text-slate-800">
      {texts.heading}
    </h2>
    <p class="text-lg leading-relaxed text-slate-500">
      {texts.paragraph}
    </p>
  </div>
  <div class="flex flex-wrap gap-10 mx-auto mt-12 justify-center">
    {
      teamMembers.map((teamMemberEntry) => (
        <div class="group w-44">
          <div class="w-full aspect-square">
            <Picture
              src={teamMemberEntry.data.avatar.src}
              alt={teamMemberEntry.data.avatar.alt}
              sizes="(max-width: 800px) 100vw, 400px"
              width={400}
              height={400}
              class="team-photo w-full rounded-md bg-white object-cover object-center aspect-square"
            />
          </div>

          <div class="mt-4 text-center">
            <h3 class="text-lg text-slate-800">{teamMemberEntry.data.name}</h3>
            <p class="text-sm text-slate-500">
              {teamMemberEntry.data.title}
            </p>
          </div>
        </div>
      ))
    }
  </div>
</Container>

<style>
  .team-photo {
    transition: transform 0.25s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .group:hover .team-photo {
    will-change: transform;
    transform: translateY(-4px);
  }
</style>
