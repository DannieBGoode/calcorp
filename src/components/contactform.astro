---
import Button from "./ui/button.astro";

const { lang } = Astro.props;
let texts;

if (lang === "es") {
  texts = (await import("../content/contactform/contactform-texts.es.js")).default;
} else if (lang === "cat") {
  texts = (await import("../content/contactform/contactform-texts.cat.js")).default;
} else if (lang === "en") {
  texts = (await import("../content/contactform/contactform-texts.en.js")).default;
} else {
  // Fallback: determine the language from the URL path
  const urlPath = Astro.url.pathname;
  if (urlPath.startsWith('/es')) {
    texts = (await import("../content/contactform/contactform-texts.es.js")).default;
  } else if (urlPath.startsWith('/cat')) {
    texts = (await import("../content/contactform/contactform-texts.cat.js")).default;
  } else {
    texts = (await import("../content/contactform/contactform-texts.en.js")).default;
  }
}
---

<form
  method="POST"
  id="form"
  class="needs-validation"
  novalidate
  data-netlify="true"
  name="contact"
>
  <input type="hidden" name="form-name" value="contact" />
  <input type="checkbox" class="hidden" style="display:none" name="botcheck" />
  <div class="mb-5">
    <label for="name" class="sr-only">{texts.fullNamePlaceholder}</label><input
      id="name"
      type="text"
      placeholder={texts.fullNamePlaceholder}
      required
      class="w-full px-4 py-3 border-2 placeholder:text-gray-800 rounded-md outline-none focus:ring-4 border-gray-300 focus:border-gray-600 ring-gray-100"
      name="name"
    />
    <div class="empty-feedback invalid-feedback text-red-400 text-sm mt-1">
      {texts.fullNameFeedback}
    </div>
  </div>
  <div class="mb-5">
    <label for="email_address" class="sr-only">{texts.emailPlaceholder}</label><input
      id="email_address"
      type="email"
      placeholder={texts.emailPlaceholder}
      name="email"
      required
      class="w-full px-4 py-3 border-2 placeholder:text-gray-800 rounded-md outline-none focus:ring-4 border-gray-300 focus:border-gray-600 ring-gray-100"
    />
    <div class="empty-feedback text-red-400 text-sm mt-1">
      {texts.emailFeedback}
    </div>
    <div class="invalid-feedback text-red-400 text-sm mt-1">
      {texts.emailInvalidFeedback}
    </div>
  </div>
  <div class="mb-3">
    <label for="message" class="sr-only">{texts.messagePlaceholder}</label><textarea
      id="message"
      name="message"
      required
      placeholder={texts.messagePlaceholder}
      class="w-full px-4 py-3 border-2 placeholder:text-gray-800 rounded-md outline-none h-36 focus:ring-4 border-gray-300 focus:border-gray-600 ring-gray-100"
    ></textarea>
    <div class="empty-feedback invalid-feedback text-red-400 text-sm mt-1">
      {texts.messageFeedback}
    </div>
  </div>
  <Button type="submit" size="lg" block>{texts.sendMessageButton}</Button>
  <div id="result" class="mt-3 text-center result-msg" aria-live="polite"></div>
</form>

<style>
  .invalid-feedback,
  .empty-feedback {
    display: none;
  }

  .was-validated :placeholder-shown:invalid ~ .empty-feedback {
    display: block;
  }

  .was-validated :not(:placeholder-shown):invalid ~ .invalid-feedback {
    display: block;
  }

  .is-invalid,
  .was-validated :invalid {
    border-color: #dc3545;
  }

  @keyframes resultIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .result-msg.is-visible {
    animation: resultIn 0.4s cubic-bezier(0.25, 1, 0.5, 1) both;
  }
</style>

<script is:inline>
  const form = document.getElementById("form");
  const result = document.getElementById("result");
  const formTexts = { ...texts }; // Ensure texts are available in the script

  function showResult(html, colorClass) {
    result.className = "mt-3 text-center result-msg " + (colorClass || "");
    result.innerHTML = html;
    result.style.display = "";
    // Trigger animation
    void result.offsetWidth;
    result.classList.add("is-visible");
  }

  form.addEventListener("submit", function (e) {
    e.preventDefault();
    form.classList.add("was-validated");
    if (!form.checkValidity()) {
      form.querySelectorAll(":invalid")[0].focus();
      return;
    }
    const formData = new FormData(form);
    const object = Object.fromEntries(formData);
    const json = JSON.stringify(object);

    showResult(formTexts.sendingMessage, "text-slate-500");

    fetch("/", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Accept: "application/json",
      },
      body: json,
    })
      .then(async (response) => {
        await response.json();
        if (response.status == 200) {
          showResult(formTexts.successMessage, "text-green-600");
        } else {
          console.log(response);
          showResult(formTexts.errorMessage, "text-red-500");
        }
      })
      .catch((error) => {
        console.log(error);
        showResult(formTexts.errorMessage, "text-red-500");
      })
      .then(function () {
        form.reset();
        form.classList.remove("was-validated");
        setTimeout(() => {
          result.style.display = "none";
          result.className = "mt-3 text-center result-msg";
        }, 5000);
      });
  });
</script>
