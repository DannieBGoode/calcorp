---
import { Picture } from "astro:assets";
import heroImage from "assets/hero.png";
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";

const { lang = "en" } = Astro.props;

let heroTexts;
if (lang === "es") {
  heroTexts = (await import("../content/hero/hero-texts.es.js")).heroTexts;
} else if (lang === "cat") {
  heroTexts = (await import("../content/hero/hero-texts.cat.js")).heroTexts;
} else {
  heroTexts = (await import("../content/hero/hero-texts.js")).heroTexts;
}
---

<main
  class="grid lg:grid-cols-2 place-items-center pt-16 pb-8 md:pt-12 md:pb-24">
  <div class="py-6 md:order-1 hidden md:block hero-image">
    <Picture
      src={heroImage}
      alt=""
      widths={[200, 400, 600]}
      sizes="(max-width: 800px) 100vw, 620px"
      loading="eager"
      format="avif"
    />
  </div>
  <div>
    <h1
      class="hero-item text-5xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter"
      style="--i:0">
      {heroTexts.heading}
    </h1>
    <p class="hero-item text-lg mt-4 text-slate-600 max-w-xl" style="--i:1">
      {heroTexts.paragraph}
    </p>
    <div class="hero-item mt-6 flex flex-col sm:flex-row gap-3" style="--i:2">
      <Link
        href="#services"
        class="flex gap-1 items-center justify-center">
        <Icon class="text-white w-5 h-5" name="bx:bxs-cloud-download" aria-hidden="true" />
         {heroTexts.exploreServices}
      </Link>
      <Link
        size="lg"
        style="outline"
        rel="noopener"
        href={
          lang === "es"
            ? "/es/contacto"
            : lang === "cat"
            ? "/cat/contacte"
            : "/contact"
        }
        class="flex gap-1 items-center justify-center">
        <Icon class="text-black w-4 h-4" name="bx:bxs-message" aria-hidden="true" />
         {heroTexts.contactUs}
      </Link>
    </div>
  </div>
</main>

<style>
  @keyframes heroIn {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-item {
    animation: heroIn 0.65s cubic-bezier(0.25, 1, 0.5, 1) both;
    animation-delay: calc(0.08s + var(--i, 0) * 0.12s);
  }

  .hero-image {
    animation: heroIn 0.8s cubic-bezier(0.25, 1, 0.5, 1) 0.15s both;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-item,
    .hero-image { animation: none; }
  }
</style>
