---
import { Icon } from "astro-icon/components";

const { lang = "en" } = Astro.props;

let eorFeatures;
if (lang === "es") {
  eorFeatures = (await import("../content/eor/features-texts.es.js")).eorFeatures;
} else if (lang === "cat") {
  eorFeatures = (await import("../content/eor/features-texts.cat.js")).eorFeatures;
} else {
  eorFeatures = (await import("../content/eor/features-texts.js")).eorFeatures;
}
---

<div id="benefits" class="mt-16" data-reveal>
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    {eorFeatures.heading}
  </h2>
  <p class="text-lg mt-4 text-slate-600">
    {eorFeatures.paragraph}
  </p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-16">
  {
    eorFeatures.features.map((item, index: number) => (
      <div class="feature-card flex gap-4 items-start" data-reveal style={`--reveal-delay: ${index * 0.05}s`}>
        <div class="feature-icon mt-1 bg-black rounded-full p-2 w-8 h-8 shrink-0">
          <Icon class="text-white" name={item.icon} />
        </div>
        <div>
          <h3 class="font-semibold text-lg">{item.title}</h3>
          <p class="text-slate-500 mt-2 leading-relaxed">{item.description}</p>
        </div>
      </div>
    ))
  }
</div>

<style>
  .feature-icon {
    transition: transform 0.25s cubic-bezier(0.25, 1, 0.5, 1);
    will-change: transform;
  }
  .feature-card:hover .feature-icon {
    transform: scale(1.15) rotate(-8deg);
  }
</style>
