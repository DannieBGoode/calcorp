---
import { Image } from "astro:assets";
import { clients } from "../content/clients.js";

import summitImg from "../assets/logos/image.webp";
import iohkImg from "../assets/logos/iohk-logo-vector.svg";
import moralisImg from "../assets/logos/Moralis-Developers-Logo-Light.webp";
import identusImg from "../assets/logos/identus-navbar-light.png";

const logoMap = {
  "Summit Advisors": summitImg,
  "IOHK": iohkImg,
  "Moralis": moralisImg,
  "Hyperledger Identus": identusImg,
};

const { lang = "en" } = Astro.props;

let logosTexts;
if (lang === "es") {
  logosTexts = (await import("../content/logos-texts.es.js")).logosTexts;
} else if (lang === "cat") {
  logosTexts = (await import("../content/logos-texts.cat.js")).logosTexts;
} else {
  logosTexts = (await import("../content/logos-texts.js")).logosTexts;
}
---

<div class="mt-24">
  <h2 class="text-center text-slate-500">{logosTexts.heading}</h2>
  <div class="flex gap-8 md:gap-16 items-center justify-center mt-10 flex-wrap">
    {
      clients.map(client => (
        <a href={client.href} target="_blank" rel="noopener noreferrer" title={client.name}>
          <div class="w-40 h-20 flex items-center justify-center overflow-hidden">
            <Image
              src={logoMap[client.name]}
              alt={client.alt}
              width={client.width}
              height={client.height}
              loading="lazy"
              class="object-contain w-full h-full"
            />
          </div>
        </a>
      ))
    }
  </div>
</div>
